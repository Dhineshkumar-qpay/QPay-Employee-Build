/* ================================
   MY PROJECTS
   ================================ */
.projects-container {
  padding-bottom: 24px;
}

.page-header {
  margin-bottom: 28px;
}

.page-header h2 {
  font-size: 26px;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 6px;
  letter-spacing: -0.02em;
}

.page-subtitle {
  color: var(--text-muted);
  font-size: 14px;
  margin: 0;
}

/* ---- Grid ---- */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 22px;
}

/* ---- Project Card ---- */
.project-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  transition:
    transform 0.25s ease,
    box-shadow 0.25s ease;
  overflow: hidden;
}

.project-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-lg);
}

/* ---- Card Header ---- */
.card-header {
  padding: 22px 22px 16px;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}

.header-project-title h3 {
  margin: 0 0 4px 0;
  font-size: 17px;
  color: var(--text-primary);
  font-weight: 700;
  line-height: 1.3;
}

.project-code {
  font-size: 11px;
  color: var(--text-muted);
  font-weight: 600;
  letter-spacing: 0.6px;
  text-transform: uppercase;
}

/* ---- Priority Badge ---- */
.priority {
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.7px;
  white-space: nowrap;
  flex-shrink: 0;
}

.priority.high {
  background: var(--danger-bg);
  color: var(--danger);
}

.priority.medium {
  background: var(--warning-bg);
  color: #b45309;
}

.priority.low {
  background: var(--success-bg);
  color: var(--success);
}

/* ---- Card Body ---- */
.card-body {
  padding: 0 22px 22px;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
}

.project-description {
  font-size: 13.5px;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 18px;
}

/* Dates stripe */
.card-dates {
  display: flex;
  justify-content: space-between;
  background: var(--bg);
  padding: 12px 16px;
  border-radius: var(--radius-md);
  margin-bottom: 14px;
  border: 1px solid var(--border-light);
}

.date-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.date-label {
  font-size: 10px;
  color: var(--text-muted);
  text-transform: uppercase;
  font-weight: 700;
  letter-spacing: 0.5px;
}

.date-value {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-secondary);
}

.deadline-value {
  color: var(--danger);
}

/* Worked info */
.worked-info-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.worked-item-card {
  display: flex;
  align-items: center;
  background: var(--bg);
  padding: 12px;
  border-radius: var(--radius-md);
  border: 1px solid var(--border-light);
  gap: 10px;
}

.icon-wrapper {
  font-size: 1.1rem;
  color: var(--brand-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.stats-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.stats-label {
  font-size: 10px;
  color: var(--text-muted);
  text-transform: uppercase;
  font-weight: 600;
  letter-spacing: 0.5px;
}

.stats-value {
  font-size: 13px;
  font-weight: 700;
  color: var(--brand-primary);
}

/* ---- Card Footer ---- */
.card-footer {
  padding: 16px 22px;
  border-top: 1px solid var(--border-light);
  background: var(--bg);
}

.add-report-btn {
  width: 100%;
  padding: 11px;
  border: none;
  border-radius: var(--radius-md);
  font-weight: 700;
  font-size: 14px;
  background: linear-gradient(135deg, #14b8a6 0%, #06433e 100%);
  color: #ffffff;
  cursor: pointer;
  transition: all 0.22s ease;
  font-family: inherit;
  letter-spacing: 0.2px;
}

.add-report-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 18px rgba(6, 67, 62, 0.25);
}

.add-report-btn:active {
  transform: scale(0.98);
}

/* ---- Empty State ---- */
.empty-projects-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  border: 2px dashed var(--border);
  padding: 60px 20px;
  text-align: center;
  margin-top: 10px;
  min-height: 360px;
}

.empty-projects-state h3 {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-secondary);
  margin-bottom: 10px;
}

.empty-projects-state p {
  font-size: 14px;
  color: var(--text-muted);
  max-width: 420px;
  line-height: 1.6;
}

@media (max-width: 640px) {
  .projects-grid {
    grid-template-columns: 1fr;
  }
}
